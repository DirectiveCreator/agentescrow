# === AgentEscrow Mainnet Deployment ===
# NEVER commit real values. Use: export PRIVATE_KEY=0x... in your terminal

# Deployer (set as env var, NOT here)
# PRIVATE_KEY=0x_NEVER_PUT_REAL_KEY_HERE

# Chain RPCs (defaults work, override if you have a private RPC)
BASE_MAINNET_RPC=https://mainnet.base.org
CELO_MAINNET_RPC=https://forno.celo.org

# Etherscan API keys (for contract verification — free at basescan.org / celoscan.io)
# BASESCAN_API_KEY=
# CELOSCAN_API_KEY=

# After deployment, fill these in:
# BASE_SERVICE_BOARD_ADDRESS=
# BASE_ESCROW_VAULT_ADDRESS=
# BASE_REPUTATION_REGISTRY_ADDRESS=
# CELO_SERVICE_BOARD_ADDRESS=
# CELO_ESCROW_VAULT_ADDRESS=
# CELO_REPUTATION_REGISTRY_ADDRESS=

# Frontend env vars (set in Render dashboard):
# NEXT_PUBLIC_ENABLE_MAINNET=false
# NEXT_PUBLIC_BASE_MAINNET_SERVICE_BOARD=
# NEXT_PUBLIC_BASE_MAINNET_ESCROW_VAULT=
# NEXT_PUBLIC_BASE_MAINNET_REPUTATION_REGISTRY=

# Demo script (post-deployment verification)
# BUYER_KEY=0x...
# SELLER_KEY=0x...
# CHAIN=base
# SERVICE_BOARD=0x...
